{
    "compilerOptions": {
        "target": "ES2020",
        "module": "es2020",
        "moduleResolution": "node",
        "outDir": "./dist",
        "lib": [
            "ES2020",
            "dom"
        ],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "allowJs": true,
        "checkJs": true,
        "noImplicitAny": true,
        "noResolve": false,
        "traceResolution": false,
        "sourceMap": false
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist"]
}